rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /recommendations/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "";
    }
    match /website_recipes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}